{
  "schemaVersion": "obs-contract/1",
  "description": "Canonical event vocabulary across vscode-mssql, perftest, and (namespaced) STS. Seeded from the verified emitted inventory 2026-07-04; conformance tests in each repo keep it honest. attrsComplete:false means the attribute list is known-partial (allowed while the registry matures — unknown attrs are a docs gap, not a violation).",
  "conventions": {
    "pairing": "Marker pairs are EXPLICIT via pairsWith — suffix conventions vary (.begin/.end, begin/ready, submit/complete) and must not be guessed.",
    "prefixFamilies": "Entries with 'prefix' match dynamically-named families (rpc.<method>, sts.dispatch.<method>, ...). Family-level rules apply to every member.",
    "sts": "sts.* events arrive epoch-aligned in extension-anchored traces and are diagnostic-only there, always."
  },
  "events": [
