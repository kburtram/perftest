{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mssql-perf.local/schemas/perf-result.schema.json",
  "title": "MSSQL VS Code Perf Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "repId",
    "scenarioId",
    "passType",
    "status",
    "trace",
    "environment",
    "metrics",
    "artifacts",
    "validations",
    "errors"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "repId": {
      "type": "integer",
      "minimum": 0
    },
    "scenarioId": {
      "type": "string",
      "minLength": 1
    },
    "attemptId": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "passType": {
      "enum": [
        "measurement",
        "diagnostic",
        "calibration"
      ]
    },
    "status": {
      "enum": [
        "passed",
        "failed",
        "invalid",
        "aborted"
      ]
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "traceId"
      ],
      "properties": {
        "traceId": {
          "type": "string",
          "pattern": "^[0-9a-f]{32}$"
        },
        "rootTraceparent": {
          "type": "string"
        },
        "tracestate": {
          "type": "string"
        }
      }
    },
    "git": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gitRepo"
      },
      "default": []
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/metric"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "validations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/error"
      }
    }
  },
  "$defs": {
    "gitRepo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "sha",
        "dirty"
      ],
      "properties": {
        "repo": {
          "type": "string"
        },
        "sha": {
          "type": "string"
        },
        "dirty": {
          "type": "boolean"
        },
        "branch": {
          "type": "string"
        },
        "remote": {
          "type": "string"
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "environmentHash"
      ],
      "properties": {
        "environmentHash": {
          "type": "string"
        },
        "machineId": {
          "type": "string"
        },
        "os": {
          "type": "object",
          "additionalProperties": true
        },
        "cpu": {
          "type": "object",
          "additionalProperties": true
        },
        "memory": {
          "type": "object",
          "additionalProperties": true
        },
        "vscode": {
          "type": "object",
          "additionalProperties": true
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        },
        "sts": {
          "type": "object",
          "additionalProperties": true
        },
        "sql": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value",
        "unit",
        "component",
        "processRole",
        "source",
        "official",
        "lowerIsBetter"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "component": {
          "type": "string",
          "minLength": 1
        },
        "processRole": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "enum": [
            "marker",
            "otelSpan",
            "webviewMark",
            "sqlServerXEvents",
            "sqlStatistics",
            "processSampler",
            "dotnetCounters",
            "dotnetTrace",
            "cdp",
            "etw",
            "derived",
            "manual"
          ]
        },
        "official": {
          "type": "boolean"
        },
        "lowerIsBetter": {
          "type": "boolean"
        },
        "aggregation": {
          "type": "string"
        },
        "traceId": {
          "type": "string",
          "pattern": "^[0-9a-f]{32}$"
        },
        "spanId": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$"
        },
        "startUnixNs": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "endUnixNs": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "tags": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          }
        },
        "derivation": {
          "$ref": "#/$defs/derivation"
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "eligibility": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "measurementEligible",
            "ciGatingEligible",
            "exploratory",
            "diagnosticOnly",
            "timePlane",
            "source",
            "passType",
            "environment",
            "reason"
          ],
          "properties": {
            "measurementEligible": {
              "type": "boolean"
            },
            "ciGatingEligible": {
              "type": "boolean"
            },
            "exploratory": {
              "type": "boolean"
            },
            "diagnosticOnly": {
              "type": "boolean"
            },
            "timePlane": {
              "enum": [
                "monotonic",
                "epoch",
                "calibrated",
                "derived"
              ]
            },
            "source": {
              "type": "string",
              "minLength": 1
            },
            "passType": {
              "enum": [
                "measurement",
                "diagnostic",
                "calibration"
              ]
            },
            "environment": {
              "enum": [
                "controlledHarness",
                "interactiveHost",
                "unknown"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "derivation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "formula",
        "inputs"
      ],
      "properties": {
        "formula": {
          "type": "string"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "retention": {
          "enum": [
            "always",
            "on-regression",
            "on-failure",
            "never"
          ]
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string"
        },
        "contentType": {
          "type": "string"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "enum": [
            "passed",
            "warning",
            "failed",
            "skipped"
          ]
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "message"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "stack": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
