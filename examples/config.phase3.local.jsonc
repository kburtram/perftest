// Phase-3 bring-up: every new scenario, one rep each, external SQL provider.
// Run from the perftest repo root:
//   node packages/perftest-cli/dist/cli.js run --config examples/config.phase3.local.jsonc
{
  "schemaVersion": 2,
  "runId": "auto",
  "passType": "measurement",
  "repetitions": 1,
  "warmupRepetitions": 0,
  "scenarios": [
    "ext-first-launch",
    "debug-console-smoke",
    "query-error-path",
    "cancel-running-query",
    "large-result-100k",
    "query-large-scroll-virtual-window",
    "query-blob-xml",
    "query-many-result-sets",
    "query-wide-columns",
    "oe-expand-mixed-schema",
    "oe-expand-deep",
    "oe-refresh",
    "intellisense-completion-latency",
    "reconnect-cycle",
    "large-script-execution",
    "expand-tables-node-10k"
  ],
  "vscode": {
    "version": "stable",
    "quality": "stable",
    "launchMode": "directSpawn",
    "profileMode": "scenarioDefault",
    "workspaceRoot": "./workspaces/perf",
    "extensions": [
      {
        "id": "ms-mssql.mssql",
        "source": "developmentPath",
        "path": "../vscode-mssql/extensions/mssql"
      },
      {
        "id": "perftest.mssql-perf-driver",
        "source": "developmentPath",
        "path": "./extensions/mssql-perf-driver"
      }
    ],
    "extraArgs": [],
    "env": {
      "MSSQL_SQLTOOLSSERVICE": "C:\\repos\\test\\sqltoolsservice\\src\\Microsoft.SqlTools.ServiceLayer\\bin\\Debug\\net10.0",
      "PERF_DOTNET_PATH": "C:\\Program Files\\dotnet\\dotnet.exe"
    }
  },
  "sql": {
    "provider": "external",
    "connectionStringEnv": "STS2_SQLSERVER_CONNSTRING",
    "snapshot": "seed-v2",
    "cacheMode": "warm",
    "connectionProfile": "default"
  },
  "environment": { "requireIdle": false },
  "diagnostics": { "markers": true, "processSampler": false, "otel": "off" },
  "store": { "type": "sqlite", "path": "./perf.db" },
  "regression": { "baseline": "none", "failOnRegression": false },
  "output": { "dir": "./perf-runs", "keepArtifacts": "always" }
}
